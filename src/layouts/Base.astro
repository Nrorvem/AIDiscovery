---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  navPages: Array<{ slug: string; title: string }>;
}

const { title, navPages } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AI Discovery</title>
    <meta name="description" content="AI Discovery helps Bay Area HVAC companies get recommended by AI search tools like ChatGPT and Google AI. Clean listings, service pages, and structured data." />

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | AI Discovery`} />
    <meta property="og:description" content="Get your Bay Area HVAC business recommended by AI search tools. Clean data, clear service pages, structured markup." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | AI Discovery`} />
    <meta name="twitter:description" content="AI Discovery helps Bay Area HVAC companies get found by AI-powered search." />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Nav pages={navPages} />
    <main id="main-content">
      <slot />
    </main>
    <Footer pages={navPages} />

    <!-- Scroll fade-in
         To disable: delete this script block. Elements remain fully visible.
         Motion guard: script checks prefers-reduced-motion before touching the DOM,
         so zero animation fires for users who have that preference set. -->
    <script>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );

        document.querySelectorAll<HTMLElement>('main > .section').forEach(el => {
          el.setAttribute('data-animate', '');
          observer.observe(el);
        });
      }
    </script>
  </body>
</html>
