---
/**
 * Container
 * Constrains content to --container-max width, centered with horizontal padding.
 * Drop inside any semantic element (<main>, <header>, etc.) when you need a
 * max-width wrapper without adding extra semantic meaning.
 *
 * Usage:
 *   <Container>…</Container>
 */
---

<div class="container">
  <slot />
</div>
