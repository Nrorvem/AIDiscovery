---
/**
 * Card
 * A surface-coloured, bordered, shadow-lifted box used inside a .cards grid.
 * The CTA field inside a card is pushed to the bottom automatically via
 * "margin-top: auto" in global.css (.card .field-cta, .card .field-button).
 *
 * Usage:
 *   <div class="cards">
 *     <Card>…content…</Card>
 *     <Card index={1}>…content…</Card>
 *   </div>
 */

interface Props {
  index?: number;
}

const { index } = Astro.props;
const attrs = typeof index === 'number' ? { 'data-card-index': String(index) } : {};
---

<div class="card" {...attrs}>
  <slot />
</div>
