---
/**
 * HeroIllustration
 * Decorative signal-flow diagram: Website / Listings / GBP → AI Engine
 * Purely decorative (aria-hidden). Inline SVG, no external deps.
 */
---

<svg
  class="hero-illustration"
  viewBox="0 0 326 200"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
  role="presentation"
  fill="none"
>
  <defs>
    <marker id="hi-arr-grey" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,1 L5,3 L0,5 z" fill="#94a3b8"/>
    </marker>
    <marker id="hi-arr-blue" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
      <path d="M0,1 L5,3 L0,5 z" fill="#2563eb"/>
    </marker>
  </defs>

  <!-- Source nodes -->
  <rect x="8"  y="22"  width="76" height="28" rx="6" fill="#eff6ff" stroke="#bfdbfe" stroke-width="1.5"/>
  <rect x="8"  y="86"  width="76" height="28" rx="6" fill="#eff6ff" stroke="#bfdbfe" stroke-width="1.5"/>
  <rect x="8"  y="150" width="76" height="28" rx="6" fill="#eff6ff" stroke="#bfdbfe" stroke-width="1.5"/>

  <text x="46" y="40"  text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="11" font-weight="600" fill="#1d4ed8">Website</text>
  <text x="46" y="104" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="11" font-weight="600" fill="#1d4ed8">Listings</text>
  <text x="46" y="168" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="11" font-weight="600" fill="#1d4ed8">GBP</text>

  <!-- Connector lines from source nodes to AI Engine -->
  <line x1="84" y1="36"  x2="157" y2="96"  stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#hi-arr-grey)"/>
  <line x1="84" y1="100" x2="157" y2="100" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#hi-arr-grey)"/>
  <line x1="84" y1="164" x2="157" y2="104" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#hi-arr-grey)"/>

  <!-- AI Engine hub -->
  <rect x="163" y="72" width="100" height="56" rx="10" fill="#2563eb"/>
  <text x="213" y="96"  text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="12" font-weight="700" fill="white">AI</text>
  <text x="213" y="114" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="12" font-weight="700" fill="white">Engine</text>

  <!-- Output arrow -->
  <line x1="263" y1="100" x2="292" y2="100" stroke="#2563eb" stroke-width="2" marker-end="url(#hi-arr-blue)"/>

  <!-- Output signal node -->
  <circle cx="308" cy="100" r="13" fill="#eff6ff" stroke="#2563eb" stroke-width="1.5"/>
  <circle cx="308" cy="100" r="5"  fill="#2563eb"/>
</svg>
