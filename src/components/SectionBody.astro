---
/**
 * SectionBody
 * Renders the inner content of a parsed Section: its direct level-2 fields
 * and any level-3 subsections displayed as a card grid.
 *
 * Used by [...slug].astro so that the same inner rendering logic works
 * whether a section sits alone or inside a pricing-tier grid wrapper.
 */

import Card from './Card.astro';
import SectionIcon from './SectionIcon.astro';
import { renderBlockBody } from '../lib/content.ts';
import type { Section as ContentSection } from '../lib/content.ts';

interface Props {
  section: ContentSection;
}

const { section } = Astro.props;

// Fields that produce an h2 / top-level heading and receive an icon.
const HEADING_FIELD_SUFFIXES = new Set(['headline', 'h1']);

// Pre-compute visible subsection cards
const visibleCards = section.subsections.filter(
  sub => sub.body.trim() || sub.fields.some(f => f.body.trim())
);

// Does this section have a heading field that will receive the label?
const hasHeadingField = section.directFields.some(f => {
  const s = (f.id.split('.').pop() ?? '').toLowerCase();
  return HEADING_FIELD_SUFFIXES.has(s);
});
---

{/* Standalone label for sections without a heading field (e.g. FAQ) */}
{!hasHeadingField && <SectionIcon sectionId={section.id} />}

{/* Body on the level-1 block itself (e.g. CONTACT.DETAILS list, NOTICE text) */}
{section.body.trim() && (
  <div class="field" set:html={renderBlockBody(section.body, section.id)} />
)}

{/* Level-2 direct fields: headline, subhead, intro, CTA, price, etc.
    Heading fields (HEADLINE / H1) receive an inline section icon above them. */}
{section.directFields.map(field => {
  const html = renderBlockBody(field.body, field.id);
  if (!html) return null;
  const fieldSuffix = (field.id.split('.').pop() ?? '').toLowerCase();
  if (HEADING_FIELD_SUFFIXES.has(fieldSuffix)) {
    return (
      <div class={`field field-${fieldSuffix}`}>
        <SectionIcon sectionId={section.id} />
        <Fragment set:html={html} />
      </div>
    );
  }
  return <div class={`field field-${fieldSuffix}`} set:html={html} />;
})}

{/* Level-3 sub-sections rendered as a card grid.
    Examples: HOME.OFFERS.A/B/C, HOME.HOW_IT_WORKS.STEP_1/2/3 */}
{visibleCards.length > 0 && (
  <div class="cards">
    {visibleCards.map((sub, i) => (
      <Card index={i}>
        {sub.body.trim() && (
          <div class="field" set:html={renderBlockBody(sub.body, sub.id)} />
        )}
        {sub.fields.map(field => {
          const html = renderBlockBody(field.body, field.id);
          if (!html) return null;
          const fieldSuffix = (field.id.split('.').pop() ?? '').toLowerCase();
          return <div class={`field field-${fieldSuffix}`} set:html={html} />;
        })}
      </Card>
    ))}
  </div>
)}
