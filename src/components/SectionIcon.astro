---
/**
 * SectionIcon
 * Branded section label: inline logo SVG + short uppercase text.
 *
 * Always aria-hidden — purely decorative, never carries unique information.
 * Returns nothing for sections that should have no label (CTAs, pricing cards, etc.).
 *
 * Usage:
 *   <SectionIcon sectionId="HOME.PROBLEM" />  → logo + "THE PROBLEM"
 *   <SectionIcon sectionId="HOME.FINAL_CTA" /> → (nothing)
 */

interface Props {
  sectionId: string;
}

const { sectionId } = Astro.props;

// Full section ID → label (primary lookup)
const LABEL_MAP: Record<string, string | null> = {
  'HOME.HERO':                       'DISCOVERY',
  'HOME.PROBLEM':                    'THE PROBLEM',
  'HOME.MECHANISM':                  'OUR APPROACH',
  'HOME.ICP':                        'BEST FIT',
  'HOME.HOW_IT_WORKS':               'PROCESS',
  'HOME.OFFERS':                     'PACKAGES',
  'HOME.FAQ':                        'Q&A',
  'HOME.FINAL_CTA':                  null,
  'PRICING.HEADER':                  'PRICING',
  'PRICING.SNAPSHOT':                null,
  'PRICING.FOUNDATION_LITE':         null,
  'PRICING.FOUNDATION_STANDARD':     null,
  'SERVICES.WHAT_YOU_GET':           'SERVICES',
  'SERVICES.PROCESS':                'PROCESS',
  'SERVICES.CTA':                    null,
  'CONTACT.HEADER':                  'CONTACT',
  'CONTACT.WHAT_WE_NEED':           'GETTING STARTED',
  'CASE_STUDY_DEMO.STARTING_POINT':  'BEFORE',
  'CASE_STUDY_DEMO.FOUNDATION':      'THE BUILD',
  'CASE_STUDY_DEMO.ARTIFACTS':       'DELIVERABLES',
  'CASE_STUDY_DEMO.RESULTS':         'RESULTS',
  'CASE_STUDY_DEMO.CTA':             null,
};

// Suffix fallback for unambiguous keys not in the full-ID map
const SUFFIX_FALLBACK: Record<string, string | null> = {
  'FINAL_CTA': null,
  'CTA':       null,
};

function getLabel(id: string): string | null {
  if (id in LABEL_MAP) return LABEL_MAP[id];
  const suffix = id.split('.').pop() ?? '';
  if (suffix in SUFFIX_FALLBACK) return SUFFIX_FALLBACK[suffix];
  return null;
}

const label = getLabel(sectionId);
